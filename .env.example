# Pipeline Doctor - Configuration
# Copy this to .env and fill in your credentials

# GitLab Configuration (REQUIRED)
GITLAB_URL=https://gitlab.com
GITLAB_TOKEN=glpat-xxxxxxxxxxxx
GITLAB_PROJECT_ID=123456789
GITLAB_DEFAULT_BRANCH=main

# AI Backend - Choose One (REQUIRED)
# Option 1: OpenAI (paid, slightly better quality)
OPENAI_API_KEY=sk-proj-xxxxxxxx
OPENAI_MODEL=gpt-4o

# Option 2: Google Gemini (free tier available, 99% cheaper)
# USE_GEMINI=true
# GCP_PROJECT_ID=your-project-id
# GCP_REGION=us-central1

# Agent Behavior
MAX_FIX_ATTEMPTS=3
POLL_INTERVAL_SECONDS=30
DRY_RUN=false
