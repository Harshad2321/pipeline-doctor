# GitLab CI Auto-Fix Agent Configuration
# Copy this file to .env and fill in your actual values

# ============================================================================
# GitLab Configuration (REQUIRED)
# ============================================================================
GITLAB_URL=https://gitlab.com
GITLAB_TOKEN=your_gitlab_personal_access_token
GITLAB_PROJECT_ID=your_project_id
GITLAB_DEFAULT_BRANCH=main

# ============================================================================
# AI Backend - Choose ONE:
# Option A: Google Gemini (FREE tier, 99% cheaper)
# Option B: OpenAI GPT-4o (more expensive, slightly better quality)
# ============================================================================

# OPTION A: Use Google Gemini (RECOMMENDED - FREE!)
USE_GEMINI=true
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=us-central1

# OPTION B: Use OpenAI (Comment out if using Gemini)
# USE_GEMINI=false
# OPENAI_API_KEY=your_openai_api_key
# OPENAI_MODEL=gpt-4o

# ============================================================================
# Agent Behavior
# ============================================================================
MAX_FIX_ATTEMPTS=3
POLL_INTERVAL_SECONDS=30
DRY_RUN=false

# Optional: Local Repository Path (if not auto-cloning)
# REPO_PATH=/path/to/local/repo


# ============================================================================
# SETUP INSTRUCTIONS
# ============================================================================

# FOR GEMINI (Free Option):
# ------------------------
# 1. Create Google Cloud Project: https://console.cloud.google.com
# 2. Enable Vertex AI API:
#    gcloud services enable aiplatform.googleapis.com
# 3. Authenticate:
#    gcloud auth application-default login
# 4. Set GCP_PROJECT_ID above
# 5. Install: pip install google-cloud-aiplatform vertexai

# FOR OPENAI (Paid Option):
# -------------------------
# 1. Get API key: https://platform.openai.com/api-keys
# 2. Set OPENAI_API_KEY above
# 3. Set USE_GEMINI=false

# FOR GITLAB:
# -----------
# 1. GitLab → Settings → Access Tokens
# 2. Create token with scopes: 'api' and 'write_repository'
# 3. Set GITLAB_TOKEN above
# 4. Get Project ID from project main page
# 5. Set GITLAB_PROJECT_ID above
